<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/shutterCircleRoot"
    android:layout_width="56dp"
    android:layout_height="56dp"
    android:background="@drawable/bg_float_ar_shutter_circle"
    android:clickable="true"
    android:focusable="true">

    <TextView
        android:id="@+id/tvShutterCountdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:contentDescription="@string/ar_screenshot_shutter_cd"
        android:text="@string/ar_shutter_label"
        android:textColor="#FF000000"
        android:textSize="16sp"
        android:textStyle="bold" />
</FrameLayout>
